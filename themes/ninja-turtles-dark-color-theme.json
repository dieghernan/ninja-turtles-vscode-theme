{
	// Created with the R package rstudiothemes (c) dieghernan.
	// https://github.com/dieghernan/rstudiothemes
	"$schema": "vscode://schemas/color-theme",
	"name": "Ninja Turtles",
	"author": "dieghernan, rstudiothemes R package",
	"semanticHighlighting": true,
	"type": "dark",
	"tokenColors": [
		{
			"settings": {
				"foreground": "#ADBCBC"
			}
		},
		{
			"name": "Invalid",
			"scope": "invalid",
			"settings": {
				"foreground": "#E3331C",
				"fontStyle": "bold"
			}
		},
		{
			"name": "atrule",
			"scope": [
				"entity.name.tag.yaml",
				"keyword.control.at-rule",
				"meta.at-rule",
				"support.constant.media.css"
			],
			"settings": {
				"foreground": "#4CAF50"
			}
		},
		{
			"name": "attr-name",
			"scope": "entity.other.attribute-name.html",
			"settings": {
				"foreground": "#4CAF50"
			}
		},
		{
			"name": "attr-value",
			"scope": [
				"string.quoted.double.html",
				"string.quoted.single.html"
			],
			"settings": {
				"foreground": "#9B59B6"
			}
		},
		{
			"name": "bold",
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "boolean",
			"scope": [
				"constant.language",
				"constant.language.boolean"
			],
			"settings": {
				"foreground": "#9B59B6"
			}
		},
		{
			"name": "class",
			"scope": "entity.other.attribute-name.class.css",
			"settings": {
				"foreground": "#007BFF"
			}
		},
		{
			"name": "class-name",
			"scope": "entity.name.type.class",
			"settings": {
				"foreground": "#007BFF"
			}
		},
		{
			"name": "code",
			"scope": [
				"text.html.markdown markup.inline.raw",
				"text.html.markdown markup.raw"
			],
			"settings": {
				"foreground": "#007BFF"
			}
		},
		{
			"name": "comment",
			"scope": "comment",
			"settings": {
				"foreground": "#474F53"
			}
		},
		{
			"name": "content",
			"scope": "meta.embedded.line",
			"settings": {
				"foreground": "#FF4500"
			}
		},
		{
			"name": "constant",
			"scope": "variable.other.constant",
			"settings": {
				"foreground": "#9B59B6"
			}
		},
		{
			"name": "doctype",
			"scope": [
				"meta.tag.metadata.doctype",
				"meta.tag.sgml.doctype.html",
				"meta.tag.sgml.html"
			],
			"settings": {
				"foreground": "#474F53"
			}
		},
		{
			"name": "function",
			"scope": [
				"entity.name.function",
				"support.function"
			],
			"settings": {
				"foreground": "#007BFF"
			}
		},
		{
			"name": "important",
			"scope": [
				"constant.numeric.yaml-version",
				"entity.other.document",
				"keyword.other.directive",
				"keyword.other.important",
				"meta.directives",
				"punctuation.definition.alias",
				"punctuation.definition.anchor",
				"punctuation.section.embedded",
				"variable.other.alias",
				"variable.other.anchor"
			],
			"settings": {
				"foreground": "#4CAF50",
				"fontStyle": "bold"
			}
		},
		{
			"name": "italic",
			"scope": "markup.italic",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"name": "keyword",
			"scope": [
				"constant.language.undefined",
				"keyword",
				"markup.inline.raw",
				"markup.raw",
				"storage"
			],
			"settings": {
				"foreground": "#4CAF50"
			}
		},
		{
			"name": "keyword-null",
			"scope": "constant.language.null",
			"settings": {
				"foreground": "#9B59B6"
			}
		},
		{
			"name": "namespace,",
			"scope": [
				"entity.name.type.namespace",
				"storage.modifier.import"
			],
			"settings": {
				"foreground": "#007BFF"
			}
		},
		{
			"name": "number",
			"scope": "constant.numeric",
			"settings": {
				"foreground": "#9B59B6"
			}
		},
		{
			"name": "operator",
			"scope": [
				"keyword.operator.arithmetic",
				"keyword.operator.assignment",
				"keyword.operator.class",
				"keyword.operator.comparison",
				"keyword.operator.logical",
				"keyword.operator.relational",
				"keyword.other",
				"punctuation.separator.dictionary.key-value"
			],
			"settings": {
				"foreground": "#4CAF50"
			}
		},
		{
			"name": "property",
			"scope": [
				"meta.property-list",
				"support.type.property-name",
				"support.type.property-name.css",
				"support.type.vendored.property-name",
				"variable.other.property"
			],
			"settings": {
				"foreground": "#FFA500"
			}
		},
		{
			"name": "punctuation",
			"scope": [
				"punctuation.definition.tag",
				"punctuation.separator"
			],
			"settings": {
				"foreground": "#ADBCBC"
			}
		},
		{
			"name": "regex",
			"scope": "string.regexp",
			"settings": {
				"foreground": "#9B59B6"
			}
		},
		{
			"name": "selector",
			"scope": [
				"meta.selector",
				"source.css entity.name.tag",
				"source.css entity.other.attribute-name"
			],
			"settings": {
				"foreground": "#4CAF50"
			}
		},
		{
			"name": "string",
			"scope": "string",
			"settings": {
				"foreground": "#9B59B6"
			}
		},
		{
			"name": "tag",
			"scope": [
				"meta.document.yaml",
				"meta.tag",
				"storage.type.tag"
			],
			"settings": {
				"foreground": "#007BFF"
			}
		},
		{
			"name": "title",
			"scope": "markup.heading",
			"settings": {
				"foreground": "#FFC324",
				"fontStyle": "bold"
			}
		},
		{
			"name": "variable",
			"scope": "variable.other.object",
			"settings": {
				"foreground": "#ADBCBC"
			}
		},
		{
			"name": "url",
			"scope": "markup.underline.link",
			"settings": {
				"foreground": "#007BFF"
			}
		},
		{
			"name": "CSS text",
			"scope": [
				"meta.property-list.css",
				"source.css keyword.other"
			],
			"settings": {
				"foreground": "#007BFF"
			}
		},
		{
			"name": "SCSS variable",
			"scope": "source.css variable",
			"settings": {
				"foreground": "#FF4500"
			}
		}
	],
	"colors": {
		"activityBar.activeBackground": "#1A3122",
		"activityBar.background": "#0E1418",
		"activityBar.foreground": "#4CAF50",
		"activityBar.inactiveForeground": "#474F53",
		"activityBarBadge.background": "#4CAF50",
		"activityBarBadge.foreground": "#0D1117",
		"background": "#0D1117",
		"badge.background": "#4CAF50",
		"badge.foreground": "#0D1117",
		"breadcrumb.activeSelectionForeground": "#ADBCBC",
		"breadcrumb.background": "#1D2228",
		"breadcrumb.focusForeground": "#ADBCBC",
		"breadcrumb.foreground": "#474F53",
		"button.background": "#4CAF50",
		"button.foreground": "#0D1117",
		"button.secondaryBackground": "#0E1418",
		"button.secondaryForeground": "#ADBCBC",
		"dropdown.background": "#1D2228",
		"dropdown.foreground": "#ADBCBC",
		"editor.background": "#0D1117",
		"editor.foreground": "#ADBCBC",
		"editor.lineHighlightBackground": "#1C2129",
		"editor.lineHighlightBorder": "#1C2129",
		"editor.selectionBackground": "#1C2129",
		"editor.snippetFinalTabstopHighlightBackground": "#0D1117",
		"editor.snippetTabstopHighlightBackground": "#0D1117",
		"editor.snippetTabstopHighlightBorder": "#474F53",
		"editorBracketHighlight.foreground1": "#ADBCBC",
		"editorCodeLens.foreground": "#474F53",
		"editorCursor.foreground": "#4CAF50",
		"editorGroupHeader.tabsBackground": "#0E1418",
